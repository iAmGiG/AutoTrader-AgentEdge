[flake8]
# Flake8 configuration for AutoGen-Trader
# Delegates most checks to Ruff, but keeps flake8 for additional coverage

# Maximum line length
max-line-length = 100

# Ignore specific error codes
ignore =
    E203,  # Whitespace before ':' (conflicts with Black)
    E501,  # Line too long (handled by Black)
    W503,  # Line break before binary operator (conflicts with Black)
    E402,  # Module level import not at top (many files have path inserts)
    F401,  # Imported but unused (handled by Ruff)
    F841,  # Local variable assigned but never used (handled by Ruff)

# Exclude directories
exclude =
    .git,
    __pycache__,
    .cache,
    .pytest_cache,
    venv,
    env,
    .venv,
    build,
    dist,
    *.egg-info,
    deprecated,
    src/deprecated

# Per-file ignores
per-file-ignores =
    __init__.py:F401,F403
    tests/*:F401,F811

# Show source code for errors
show-source = True

# Show statistics
statistics = True

# Count errors
count = True
